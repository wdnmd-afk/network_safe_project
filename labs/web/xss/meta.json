{
  "id": "web.xss",
  "slug": "xss",
  "title": "XSS",
  "category": "web",
  "subcategory": "xss",
  "mode": "interactive",
  "severity": "high",
  "difficulty": "beginner",
  "summary": "在客服留言业务上下文中对比未转义输出与文本渲染的 XSS 风险差异。",
  "status": "ready",
  "phase": "phase-1",
  "tags": ["web", "xss", "output-encoding"],
  "knowledgePoints": [
    "用户输入不应直接作为 HTML 输出",
    "漏洞版使用 HTML 渲染会改变页面结构",
    "修复版使用文本渲染避免解释用户输入"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "客服留言内容被当作 HTML 渲染，用惰性标记模拟 XSS 风险信号。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "提交样例后页面出现 data-xss-lab-signal 标记对应的黄色模拟信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "客服留言内容以文本方式展示，同样输入不会改变页面结构。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "提交样例后页面原样显示 HTML 字符串，不解释为页面标记。",
      "supportsAutomation": true
    }
  ],
  "entrypoints": {
    "web": [
      {
        "key": "vuln-entry",
        "path": "/labs/web/xss/vuln",
        "description": "XSS 漏洞版客服留言页面",
        "variant": "vuln"
      },
      {
        "key": "fixed-entry",
        "path": "/labs/web/xss/fixed",
        "description": "XSS 修复版客服留言页面",
        "variant": "fixed"
      }
    ],
    "api": [],
    "scripts": [
      {
        "key": "xss-verify",
        "language": "ts",
        "path": "tools/lab-scripts/web/xss/verify.ts",
        "description": "本机受控 XSS 漏洞版与修复版差异验证配置"
      }
    ],
    "docs": [
      {
        "key": "overview",
        "path": "labs/web/xss/README.md",
        "description": "实验总说明"
      },
      {
        "key": "attack-steps",
        "path": "labs/web/xss/docs/attack-steps.md",
        "description": "漏洞版观察步骤"
      },
      {
        "key": "fix-notes",
        "path": "labs/web/xss/docs/fix-notes.md",
        "description": "修复版实现说明"
      },
      {
        "key": "manual-verification",
        "path": "labs/web/xss/docs/manual-verification.md",
        "description": "手动验证步骤"
      }
    ]
  },
  "verification": {
    "manual": {
      "supported": true,
      "stepsDocPath": "labs/web/xss/docs/manual-verification.md",
      "expectedSignals": [
        "漏洞版会出现黄色 XSS 模拟信号",
        "修复版会原样显示 HTML 字符串"
      ]
    },
    "automation": {
      "supported": true,
      "playwright": {
        "enabled": true,
        "specPath": "packages/testing/tests/e2e/platform.spec.mjs"
      },
      "apiTest": {
        "enabled": false,
        "specPath": ""
      },
      "scriptVerification": {
        "enabled": true,
        "scriptKeys": ["xss-verify"]
      }
    }
  },
  "prerequisites": [],
  "paths": {
    "root": "labs/web/xss",
    "readme": "labs/web/xss/README.md",
    "vuln": "labs/web/xss/vuln",
    "fixed": "labs/web/xss/fixed",
    "mock": "labs/web/xss/mock",
    "docs": "labs/web/xss/docs",
    "scripts": "tools/lab-scripts/web/xss"
  }
}
