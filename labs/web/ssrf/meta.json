{
  "id": "web.ssrf",
  "slug": "ssrf",
  "title": "SSRF",
  "category": "web",
  "subcategory": "ssrf",
  "mode": "interactive",
  "severity": "high",
  "difficulty": "intermediate",
  "summary": "在受控虚拟 URL 抓取业务中对比未限制服务端请求目标与白名单阻断的攻防差异。",
  "status": "ready",
  "phase": "phase-1",
  "tags": ["web", "ssrf", "server-side-request"],
  "knowledgePoints": [
    "服务端请求伪造",
    "私有地址阻断",
    "主机白名单",
    "虚拟资源索引",
    "实验事件日志"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "URL 预览接口未限制服务端请求目标，受控内部元数据样例会被模拟读取。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 ssrf-internal-metadata-exposed 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "URL 预览接口只允许公开白名单主机，并阻断私有地址、链路本地地址和内部域名。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 ssrf-private-target-blocked 信号。",
      "supportsAutomation": true
    }
  ],
  "entrypoints": {
    "web": [
      {
        "key": "vuln-entry",
        "path": "/labs/web/ssrf/vuln",
        "description": "SSRF 漏洞版实验入口",
        "variant": "vuln"
      },
      {
        "key": "fixed-entry",
        "path": "/labs/web/ssrf/fixed",
        "description": "SSRF 修复版实验入口",
        "variant": "fixed"
      }
    ],
    "api": [
      {
        "key": "vuln-fetch-api",
        "path": "/api/labs/web/ssrf/vuln/fetch",
        "description": "漏洞版虚拟 URL 抓取接口",
        "variant": "vuln",
        "method": "POST"
      },
      {
        "key": "fixed-fetch-api",
        "path": "/api/labs/web/ssrf/fixed/fetch",
        "description": "修复版虚拟 URL 抓取接口",
        "variant": "fixed",
        "method": "POST"
      }
    ],
    "scripts": [
      {
        "key": "ssrf-exploit",
        "language": "python",
        "path": "tools/lab-scripts/web/ssrf/exploit.py",
