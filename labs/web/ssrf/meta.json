      },
      {
        "key": "fix-notes",
        "path": "labs/web/ssrf/docs/fix-notes.md",
        "description": "修复说明"
      },
      {
        "key": "manual-verification",
        "path": "labs/web/ssrf/docs/manual-verification.md",
