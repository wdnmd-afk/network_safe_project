    "越权读取风险",
    "实验事件日志"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "文档预览接口拼接用户输入路径后未确认最终路径仍在 public 目录内，受控遍历样例会读取内部模拟文档。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 path-traversal-sensitive-file-exposed 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "文档预览接口规范化路径后要求最终路径仍位于 public 目录内，逃逸请求会被阻断。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 path-traversal-normalized-blocked 信号。",
      "supportsAutomation": true
    }
  ],
