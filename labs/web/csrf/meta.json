{
  "id": "web.csrf",
  "slug": "csrf",
  "title": "CSRF",
  "category": "web",
  "subcategory": "csrf",
  "mode": "interactive",
  "severity": "high",
  "difficulty": "beginner",
  "summary": "在账户转账业务中对比缺少 CSRF token 校验与一次性 token 防护的行为差异。",
  "status": "ready",
  "phase": "phase-1",
  "tags": ["web", "csrf", "request-forgery"],
  "knowledgePoints": [
    "CSRF 利用的是用户已登录状态下浏览器会携带身份凭据的业务特性",
    "只检查登录态不能确认请求一定来自当前页面",
    "修复版通过后端颁发并校验一次性 CSRF token 阻断伪造请求"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "转账接口只验证登录态，不要求 CSRF token，本机受控模拟第三方请求会被接受。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "点击模拟第三方请求后，账户余额减少并出现 csrf-transfer-accepted 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "转账接口要求后端颁发的一次性 CSRF token，缺少 token 的模拟第三方请求会被阻断。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "点击模拟第三方请求后，余额不变并出现 csrf-token-required 信号；正常提交携带 token 可成功。",
      "supportsAutomation": true
    }
  ],
  "entrypoints": {
    "web": [
      {
        "key": "vuln-entry",
        "path": "/labs/web/csrf/vuln",
        "description": "CSRF 漏洞版转账实验页面",
        "variant": "vuln"
      },
      {
        "key": "fixed-entry",
        "path": "/labs/web/csrf/fixed",
        "description": "CSRF 修复版转账实验页面",
        "variant": "fixed"
      }
    ],
    "api": [
      {
        "key": "csrf-state",
        "method": "GET",
        "path": "/api/labs/web/csrf/state",
        "description": "读取当前登录用户的 CSRF 实验状态"
      },
      {
        "key": "csrf-vuln-transfer",
        "method": "POST",
        "path": "/api/labs/web/csrf/vuln/transfer",
        "description": "漏洞版转账接口，不要求 CSRF token",
        "variant": "vuln"
      },
      {
        "key": "csrf-fixed-token",
        "method": "POST",
        "path": "/api/labs/web/csrf/fixed/token",
        "description": "修复版 CSRF token 颁发接口",
        "variant": "fixed"
      },
      {
        "key": "csrf-fixed-transfer",
        "method": "POST",
        "path": "/api/labs/web/csrf/fixed/transfer",
        "description": "修复版转账接口，要求 CSRF token",
        "variant": "fixed"
      }
    ],
    "scripts": [
      {
        "key": "csrf-local-exploit",
        "language": "python",
        "path": "tools/lab-scripts/web/csrf/exploit.py",
        "description": "仅限 localhost 的 CSRF 受控请求模拟脚本"
      },
      {
        "key": "csrf-verify",
        "language": "ts",
        "path": "tools/lab-scripts/web/csrf/verify.ts",
        "description": "本机受控 CSRF 漏洞版与修复版差异验证配置"
      }
    ],
    "docs": [
      {
        "key": "overview",
        "path": "labs/web/csrf/README.md",
        "description": "实验总说明"
      },
      {
        "key": "attack-steps",
        "path": "labs/web/csrf/docs/attack-steps.md",
        "description": "漏洞版观察步骤"
      },
      {
        "key": "fix-notes",
        "path": "labs/web/csrf/docs/fix-notes.md",
        "description": "修复版实现说明"
      },
      {
        "key": "manual-verification",
        "path": "labs/web/csrf/docs/manual-verification.md",
        "description": "手动验证步骤"
      }
    ]
  },
  "verification": {
    "manual": {
      "supported": true,
      "stepsDocPath": "labs/web/csrf/docs/manual-verification.md",
      "expectedSignals": [
        "漏洞版模拟第三方请求返回 csrf-transfer-accepted",
        "修复版模拟第三方请求返回 csrf-token-required",
        "修复版正常提交携带 token 返回 csrf-token-accepted"
      ]
    },
    "automation": {
      "supported": true,
      "playwright": {
        "enabled": true,
        "specPath": "packages/testing/tests/e2e/platform.spec.mjs"
      },
      "apiTest": {
        "enabled": true,
        "specPath": "apps/server/tests/csrf-lab.test.ts"
      },
      "scriptVerification": {
        "enabled": true,
        "scriptKeys": ["csrf-verify"]
      }
    }
  },
  "prerequisites": [
    {
      "type": "account",
      "description": "需要使用本机演示账号登录后触发受控业务请求"
    }
  ],
  "paths": {
    "root": "labs/web/csrf",
    "readme": "labs/web/csrf/README.md",
    "vuln": "labs/web/csrf/vuln",
    "fixed": "labs/web/csrf/fixed",
    "mock": "labs/web/csrf/mock",
    "docs": "labs/web/csrf/docs",
    "scripts": "tools/lab-scripts/web/csrf"
  },
  "sortOrder": 20,
  "estimatedMinutes": 25
}
