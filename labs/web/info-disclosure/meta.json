      "expectedOutcome": "出现 info-disclosure-debug-data-exposed 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "诊断报告接口只允许公开报告，调试报告被阻断并返回通用说明。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 info-disclosure-debug-data-blocked 信号。",
      "supportsAutomation": true
    }
  ],
  "entrypoints": {
