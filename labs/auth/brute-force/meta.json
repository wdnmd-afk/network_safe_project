  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "接口没有失败次数阈值，会持续检查候选口令，直到猜中虚拟教学账号。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 brute-force-password-guessed 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "接口在连续失败达到 3 次后触发节流，停止继续检查后续候选口令。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 brute-force-rate-limit-blocked 信号。",
      "supportsAutomation": true
    }
  ],
