  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "JWT 验证器信任 header 中的 alg，当 alg=none 时跳过签名校验并接受管理员声明。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 jwt-none-alg-admin-accepted 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "JWT 验证器只允许 HS256 教学 token，并强制校验签名后再读取声明。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 jwt-none-alg-blocked 信号。",
      "supportsAutomation": true
    }
  ],
