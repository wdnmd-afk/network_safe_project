  "severity": "high",
  "difficulty": "intermediate",
  "summary": "在受控教学登录会话中对比继续使用客户端预登录会话 ID 与登录后服务端轮换会话 ID 的攻防差异。",
  "status": "ready",
  "phase": "phase-1",
  "tags": ["auth", "session-fixation", "session-management"],
  "knowledgePoints": [
    "会话固定成因",
    "登录后会话轮换",
    "客户端会话 ID 信任边界",
    "Cookie 与会话安全策略",
    "实验事件日志"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "接口在教学登录完成后继续使用客户端传入的 preLoginSessionId，外部链接固定 ID 会被绑定到当前用户。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 session-fixed-id-bound 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "接口在教学登录完成后忽略客户端传入的 preLoginSessionId，并由服务端生成新的教学会话 ID。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 session-fixed-id-rotated 信号。",
      "supportsAutomation": true
    }
  ],
