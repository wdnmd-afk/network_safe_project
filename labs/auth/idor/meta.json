{
  "id": "auth.idor",
  "slug": "idor",
  "title": "IDOR",
  "category": "auth",
  "subcategory": "idor",
  "mode": "interactive",
  "severity": "high",
  "difficulty": "intermediate",
  "summary": "在受控订单详情业务中对比只按对象 ID 读取与后端对象级授权校验的攻防差异。",
  "status": "ready",
  "phase": "phase-1",
  "tags": ["auth", "idor", "authorization"],
  "knowledgePoints": [
    "IDOR 成因",
    "对象级授权",
    "资源归属校验",
    "越权读取信号",
    "实验事件日志"
  ],
  "variants": [
    {
      "key": "vuln",
      "title": "漏洞版",
      "enabled": true,
      "description": "接口只按 orderId 读取订单，不校验 ownerUserId 是否属于当前登录用户。",
      "entryKey": "vuln-entry",
      "expectedOutcome": "出现 idor-cross-user-order-exposed 信号。",
      "supportsAutomation": true
    },
    {
      "key": "fixed",
      "title": "修复版",
      "enabled": true,
      "description": "接口读取订单后强制校验 ownerUserId 与当前登录用户一致，跨用户对象会被阻断。",
      "entryKey": "fixed-entry",
      "expectedOutcome": "出现 idor-cross-user-order-blocked 信号。",
      "supportsAutomation": true
    }
  ],
  "entrypoints": {
    "web": [
      {
        "key": "vuln-entry",
        "path": "/labs/auth/idor/vuln",
        "description": "IDOR 漏洞版实验入口",
        "variant": "vuln"
      },
      {
        "key": "fixed-entry",
        "path": "/labs/auth/idor/fixed",
        "description": "IDOR 修复版实验入口",
        "variant": "fixed"
      }
    ],
    "api": [
      {
        "key": "vuln-read-api",
        "path": "/api/labs/auth/idor/vuln/read",
        "description": "漏洞版 IDOR 订单读取接口",
        "variant": "vuln",
        "method": "POST"
      },
      {
        "key": "fixed-read-api",
        "path": "/api/labs/auth/idor/fixed/read",
        "description": "修复版 IDOR 订单读取接口",
        "variant": "fixed",
        "method": "POST"
      }
    ],
    "scripts": [
