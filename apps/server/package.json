{
  "name": "@network-safe/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "prisma:generate": "node ./scripts/prisma-generate.mjs",
    "prisma:validate": "node ./scripts/prisma-validate.mjs",
    "schema:ensure": "node ./scripts/ensure-local-schema.mjs",
    "seed:auth": "node ./scripts/seed-auth-users.mjs",
    "seed:labs": "tsx ./scripts/seed-lab-metadata.ts"
  },
  "dependencies": {
    "@network-safe/shared": "workspace:*",
    "dotenv": "^16.6.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
